#!/bin/sh
set -eu

usage() {
  cat <<'USAGE'
Usage:
  scripts/ci/publish-forgejo-image <tag>

Builds and pushes the Sporos container image to a Forgejo container registry.

Required environment:
  Forgejo Actions automatically provides FORGEJO_ACTOR and FORGEJO_TOKEN.

Optional environment:
  FORGEJO_REGISTRY        Registry host. Defaults to FORGEJO_IMAGE or FORGEJO_SERVER_URL host.
  FORGEJO_REGISTRY_USER   Registry username. Defaults to FORGEJO_ACTOR/GITHUB_ACTOR.
  FORGEJO_REGISTRY_TOKEN  Registry token or password. Defaults to FORGEJO_TOKEN/GITHUB_TOKEN.
  FORGEJO_IMAGE           Full image name. Defaults to <registry>/<repository>.
  FORGEJO_REPOSITORY      Owner/repository. Defaults to CI repository context.
USAGE
}

if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
  usage
  exit 0
fi

raw_tag="${1:-${FORGEJO_REF_NAME:-${GITHUB_REF_NAME:-}}}"
tag=$(printf "%s" "$raw_tag" | tr "/" "-")
if [ -z "$tag" ]; then
  echo "missing image tag" >&2
  usage >&2
  exit 2
fi
case "$tag" in
  *[!A-Za-z0-9_.-]* | .* | -*)
    echo "invalid Docker tag: $tag" >&2
    exit 2
    ;;
esac

registry="${FORGEJO_REGISTRY:-}"
if [ -z "$registry" ] && [ -n "${FORGEJO_IMAGE:-}" ]; then
  registry="${FORGEJO_IMAGE%%/*}"
fi
if [ -z "$registry" ] && [ -n "${FORGEJO_SERVER_URL:-}" ]; then
  registry=$(printf "%s" "$FORGEJO_SERVER_URL" | sed -E 's#^[a-zA-Z][a-zA-Z0-9+.-]*://##; s#/.*$##')
fi
repository="${FORGEJO_REPOSITORY:-${GITHUB_REPOSITORY:-}}"
repository=$(printf "%s" "$repository" | tr "[:upper:]" "[:lower:]")
user="${FORGEJO_REGISTRY_USER:-${FORGEJO_ACTOR:-${GITHUB_ACTOR:-}}}"
token="${FORGEJO_REGISTRY_TOKEN:-${FORGEJO_TOKEN:-${GITHUB_TOKEN:-}}}"

if [ -z "$registry" ]; then
  echo "FORGEJO_REGISTRY or FORGEJO_SERVER_URL is required" >&2
  exit 1
fi
if [ -z "$repository" ] && [ -z "${FORGEJO_IMAGE:-}" ]; then
  echo "FORGEJO_REPOSITORY or FORGEJO_IMAGE is required" >&2
  exit 1
fi
image="${FORGEJO_IMAGE:-$registry/$repository}"
if [ -z "$user" ]; then
  echo "FORGEJO_REGISTRY_USER or FORGEJO_ACTOR is required" >&2
  exit 1
fi
if [ -z "$token" ]; then
  echo "FORGEJO_REGISTRY_TOKEN or FORGEJO_TOKEN is required" >&2
  exit 1
fi

printf "%s" "$token" | docker login "$registry" --username "$user" --password-stdin
DOCKER_BUILDKIT="${DOCKER_BUILDKIT:-1}" docker build -t "$image:$tag" -f Dockerfile .
docker push "$image:$tag"
